{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "mio",
  "description": "MiMo-exclusive desktop AI coding agent",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev:desktop": "bun --cwd packages/desktop dev",
    "dev:app": "bun --cwd packages/app dev",
    "dev:agent": "bun run --cwd packages/agent --conditions=browser src/index.ts",
    "lint": "oxlint",
    "typecheck": "bun turbo typecheck",
    "postinstall": "bun run --cwd packages/agent fix-node-pty",
    "prepare": "husky",
    "test": "echo 'do not run tests from root' && exit 1"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/sdk/js"
    ],
    "catalog": {
      "@effect/opentelemetry": "4.0.0-beta.66",
      "@effect/platform-node": "4.0.0-beta.66",
      "@effect/sql-sqlite-bun": "4.0.0-beta.66",
      "@types/bun": "1.3.13",
      "@types/cross-spawn": "6.0.6",
      "@hono/zod-validator": "0.4.2",
      "ulid": "3.0.1",
      "@kobalte/core": "0.13.11",
      "@types/luxon": "3.7.1",
      "@types/node": "24.12.2",
      "@tsconfig/bun": "1.0.9",
      "@tsconfig/node22": "22.0.2",
      "@opentui/core": "0.2.16",
      "@opentui/keymap": "0.2.16",
      "@opentui/solid": "0.2.16",
      "@types/semver": "7.7.1",
      "fuzzysort": "3.1.0",
      "remend": "1.3.0",
      "ai": "6.0.168",
      "@pierre/diffs": "1.1.0-beta.18",
      "@solid-primitives/storage": "4.3.3",
      "@tailwindcss/vite": "4.1.11",
      "diff": "8.0.2",
      "dompurify": "3.3.1",
      "drizzle-kit": "1.0.0-rc.2",
      "drizzle-orm": "1.0.0-rc.2",
      "effect": "4.0.0-beta.66",
      "cross-spawn": "7.0.6",
      "hono": "4.10.7",
      "hono-openapi": "1.1.2",
      "luxon": "3.6.1",
      "marked": "17.0.1",
      "marked-shiki": "1.2.1",
      "@playwright/test": "1.59.1",
      "typescript": "5.8.2",
      "@typescript/native-preview": "7.0.0-dev.20251207.1",
      "zod": "4.1.8",
      "remeda": "2.26.0",
      "shiki": "3.20.0",
      "solid-list": "0.3.0",
      "tailwindcss": "4.1.11",
      "virtua": "0.49.1",
      "vite": "7.1.4",
      "@solidjs/meta": "0.29.4",
      "@solidjs/router": "0.15.4",
      "@sentry/solid": "10.36.0",
      "@sentry/vite-plugin": "4.6.0",
      "solid-js": "1.9.10",
      "vite-plugin-solid": "2.11.10",
      "@lydell/node-pty": "1.2.0-beta.10"
    }
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/mime-types": "3.0.1",
    "@typescript/native-preview": "catalog:",
    "glob": "13.0.5",
    "husky": "9.1.7",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.0",
    "prettier": "3.6.2",
    "turbo": "2.8.13"
  },
  "dependencies": {
    "@opencode-ai/plugin": "workspace:*",
    "@opencode-ai/sdk": "workspace:*",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shin4/mio"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "trustedDependencies": [
    "esbuild",
    "node-pty",
    "protobufjs",
    "web-tree-sitter",
    "electron"
  ],
  "overrides": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  },
  "patchedDependencies": {
    "@silvia-odwyer/photon-node@0.3.4": "patches/@silvia-odwyer%2Fphoton-node@0.3.4.patch",
    "solid-js@1.9.10": "patches/solid-js@1.9.10.patch",
    "virtua@0.49.1": "patches/virtua@0.49.1.patch"
  }
}
